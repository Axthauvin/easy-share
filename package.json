{
  "name": "easy-share",
  "version": "1.0.0",
  "description": "Simple local network text sharing tool",
  "main": "main.js",
  "bin": {
    "easy-share": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "node server.js",
    "electron": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "express": "^4.19.2",
    "flag-icons": "^7.5.0",
    "qrcode": "^1.5.4",
    "ws": "^8.16.0"
  },
  "keywords": [],
  "author": "Axthauvin <axthauvin@users.noreply.github.com>",
  "license": "ISC",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.axthauvin.easyshare",
    "productName": "Easy-Share",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Easy-Share"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "public/icon.png"
    }
  }
}
